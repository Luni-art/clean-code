from django.shortcuts import render

TEMPLATE_PREFIX = "blogblogging/"

def render_page(request, template_name):
    """Helper untuk merender halaman dengan template prefix"""
    return render(request, f"{TEMPLATE_PREFIX}{template_name}")


def index(request):
    """Menampilkan halaman utama"""
    return render_page(request, "index.html")


def galeri(request):
    """Menampilkan halaman galeri"""
    return render_page(request, "galeri.html")


def kontak(request):
    """Menampilkan halaman kontak"""
    return render_page(request, "kontak.html")
